module atmos-custom 1.0;

require {
	type http_port_t;
	type init_t;
	type sudo_exec_t;
	type tun_tap_device_t;
	type unreserved_port_t;
	class file { execute execute_no_trans map open read };
	class tcp_socket name_connect;
	class chr_file { ioctl open read write };
	class tun_socket create;
}

#============= init_t ==============
# Allow agentd to connect to HTTPS (443) and VPN tunnel ports
allow init_t http_port_t:tcp_socket name_connect;
allow init_t unreserved_port_t:tcp_socket name_connect;

# Allow agentd to create and use TUN devices for VPN tunnel
allow init_t self:tun_socket create;
allow init_t tun_tap_device_t:chr_file { ioctl open read write };

# Allow agentd to execute sudo for privilege escalation
allow init_t sudo_exec_t:file { execute execute_no_trans map open read };
