#!/bin/sh

if command -v gitleaks >/dev/null 2>&1; then
    GITLEAKS=gitleaks
elif toolbox run -c fedora-toolbox-44 true >/dev/null 2>&1; then
    GITLEAKS="toolbox run -c fedora-toolbox-44 gitleaks"
else
    echo "gitleaks not found, aborting commit"
    exit 1
fi

tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT

git diff --staged --name-only --diff-filter=d | while IFS= read -r file; do
    mkdir -p "$tmpdir/$(dirname "$file")"
    git show ":$file" > "$tmpdir/$file"
done

$GITLEAKS detect --no-git --redact -s "$tmpdir"
