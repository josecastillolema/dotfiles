[alias]
  a = add
  acdp = "!git add . && git commit -s -m \"$(date)\" && git push"
  b = branch
  c = "commit -s"
  cd = "!git commit -s -m \"$(date)\""
  cdp = "!git commit -s -m \"$(date)\"; git push"
  cleanup = "!git fetch --all --prune; git branch --merged origin/main | grep -v \"\\*\" | grep -v \"\\  main\" | xargs -n 1 git branch -d"
  co = checkout
  d = "diff --word-diff=color"
  dm = "diff --word-diff=color main"
  l = "log --color --graph --abbrev-commit --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset'"
  s = "status --ignored"
  sh = "show HEAD"
[commit]
  gpgsign = true                # sign commits with GPG
[core]
  editor = io.neovim.nvim
[diff]
  algorithm = histogram         # better diffs for moved code blocks
[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true
[format]
  signoff = true                # add Signed-off-by to patches
[gitreview]
  username = josecastillolema
[gpg]
  format = ssh                  # use SSH keys for signing
[init]
  defaultBranch = main
[merge]
  conflictstyle = zdiff3        # show base version in conflict markers
[pull]
  rebase = true                 # rebase instead of merge on pull
[push]
  autoSetupRemote = true        # auto track remote branch on first push
[rerere]
  enabled = true                # remember conflict resolutions
[tag]
  gpgsign = true                # sign tags with GPG
[user]
  name = Jose Castillo Lema
  email = josecastillolema@gmail.com
  signingkey = ~/.ssh/id_rsa.pub
