gtk-single-instance = true
font-size = 14
theme =
confirm-close-surface = false
desktop-notifications = false
cursor-style = block
shell-integration-features = no-cursor
keybind = shift+end=unbind
keybind = shift+home=unbind
keybind = shift+page_up=unbind
keybind = shift+page_down=unbind
# For claude code multiline
keybind = shift+enter=text:\x1b\x0d
keybind = ctrl+shift+up=scroll_page_lines:-10
keybind = ctrl+shift+down=scroll_page_lines:10
keybind = ctrl+shift+page_up=scroll_page_lines:-100
keybind = ctrl+shift+page_down=scroll_page_lines:100
